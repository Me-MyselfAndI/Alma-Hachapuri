# Copy to .env in repo root or backend/ and adjust.

# PostgreSQL (docker-compose or local install)
DATABASE_URL=postgresql://alma:alma@localhost:5432/alma

# API
JWT_SECRET=dev-secret-change-in-production
UPLOADS_DIR=uploads

# Frontend origin (CORS)
# CORS_ORIGINS=["http://localhost:3000"]

# Feature flags
ENABLE_LLM_ENRICHMENT=false

# Email — Mailpit when using docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025

# Frontend (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
