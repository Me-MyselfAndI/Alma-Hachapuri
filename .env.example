# Copy to .env in the repo root and adjust.
# All paths below are relative to the repo root unless absolute.
# Optional override: PROJECT_ROOT=/path/to/clone

# PostgreSQL (docker-compose or local install)
DATABASE_URL=postgresql://alma:alma@localhost:5432/alma

# API
JWT_SECRET=dev-secret-change-in-production
UPLOADS_DIR=storage/uploads

# Frontend origin (CORS)
# CORS_ORIGINS=["http://localhost:3000"]

# Feature flags
ENABLE_LLM_ENRICHMENT=false

# L1b — minutes before a stuck pending row (used_at set, no lead_id) may be reclaimed
VERIFICATION_PROCESSING_STALE_MINUTES=5

# Resume retention (F2.5) — purge job not built yet; config ready for scheduler
RESUME_RETENTION_DAYS=365

# Email — Mailpit when using docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025

# Frontend (used by Next.js — also set in webapp/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
WEBAPP_URL=http://localhost:3000
